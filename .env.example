# Токен бота, полученный у @BotFather
BOT_TOKEN=1234567890:AAAaaaAAAaaaAAAaaaAAAaaaAAAaaaAAAaa

# Список Telegram user_id администраторов через запятую (без пробелов)
# Узнать свой id можно у @userinfobot
ADMIN_IDS=111111111,222222222

# Путь к файлу SQLite (по умолчанию bot.db в корне проекта)
DATABASE_PATH=bot.db

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Часовой пояс для планировщика (IANA), например Europe/Moscow, UTC
TIMEZONE=Europe/Moscow
